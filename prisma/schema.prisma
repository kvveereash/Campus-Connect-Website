generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──

enum UserRole {
  USER
  ADMIN
  COLLEGE_ADMIN
}

enum RegistrationStatus {
  PENDING
  PENDING_PAYMENT
  CONFIRMED
  PAID
  COMPLETED
  CANCELLED
  WAITLISTED
}

enum ClubMemberRole {
  MEMBER
  ADMIN
}

enum NotificationType {
  EVENT_REMINDER
  EVENT_UPDATE
  EVENT_JOIN
  CLUB_INVITE
  CLUB_UPDATE
  CLUB_JOIN
  TEAM_REQUEST
  TEAM_CONNECT
  COMMENT
  BADGE_EARNED
  SYSTEM
  GENERAL
}

enum TeamRequestType {
  LOOKING_FOR_TEAM
  LOOKING_FOR_MEMBER
}

enum ConversationRole {
  MEMBER
  ADMIN
}

model User {
  id                         String                    @id @default(cuid())
  name                       String
  email                      String                    @unique
  password                   String
  department                 String?
  year                       String?
  avatar                     String?
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  lastSeenAt                 DateTime                  @default(now())
  role                       UserRole                  @default(USER)
  collegeId                  String?
  bio                        String?
  resumeUrl                  String?
  achievements               String?
  projects                   String?
  portfolioLinks             String?
  lockedUntil                DateTime?
  auditLogs                  AuditLog[]                @relation("AuditActor")
  messages                   ChatMessage[]
  clubMemberships            ClubMember[]
  comments                   Comment[]
  conversationParticipations ConversationParticipant[]
  createdEvents              Event[]                   @relation("CreatedEvents")
  registrations              EventRegistration[]
  eventReviews               EventReview[]
  messagesSent               Message[]
  triggeredNotifications     Notification[]            @relation("NotificationActor")
  notifications              Notification[]            @relation("UserNotifications")
  passwordResetTokens        PasswordResetToken[]
  posts                      Post[]
  reactions                  Reaction[]
  RefreshToken               RefreshToken[]
  teamRequests               TeamRequest[]
  college                    College?                  @relation(fields: [collegeId], references: [id])
  badges                     UserBadge[]
  followedColleges           College[]                 @relation("FollowedColleges")
  interests                  Interest[]                @relation("InterestToUser")
  skills                     Skill[]                   @relation("SkillToUser")

  deletedAt                  DateTime?

  @@index([email])
  @@index([collegeId])
  @@index([createdAt])
  @@index([deletedAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Skill {
  id    String @id @default(cuid())
  name  String @unique
  users User[] @relation("SkillToUser")
}

model Interest {
  id    String @id @default(cuid())
  name  String @unique
  users User[] @relation("InterestToUser")
}

model College {
  id          String   @id @default(cuid())
  name        String
  location    String
  logo        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  clubs       Club[]
  events      Event[]
  students    User[]
  followers   User[]  @relation("FollowedColleges")
}

model Event {
  id                String              @id @default(cuid())
  title             String
  description       String
  date              DateTime
  venue             String
  category          String
  registrationCount Int                 @default(0)
  thumbnail         String?
  hostCollegeId     String
  creatorId         String?
  clubId            String?
  verified          Boolean             @default(false)
  rejectionReason   String?
  verifiedBy        String?
  verifiedAt        DateTime?
  price             Float               @default(0)
  club              Club?               @relation(fields: [clubId], references: [id])
  creator           User?               @relation("CreatedEvents", fields: [creatorId], references: [id])
  hostCollege       College             @relation(fields: [hostCollegeId], references: [id])
  registrations     EventRegistration[]
  reviews           EventReview[]
  teamRequests      TeamRequest[]

  deletedAt         DateTime?

  @@index([hostCollegeId])
  @@index([date])
  @@index([category])
  @@index([creatorId])
  @@index([deletedAt])
}

model EventReview {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
}

model EventRegistration {
  id         String   @id @default(cuid())
  userId     String
  eventId    String
  status     RegistrationStatus @default(PENDING)
  paymentId  String?
  amountPaid Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  users       UserBadge[]
}

model UserBadge {
  id         String   @id @default(cuid())
  dateEarned DateTime @default(now())
  userId     String
  badgeId    String
  badge      Badge    @relation(fields: [badgeId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, badgeId])
}

model Club {
  id              String       @id @default(cuid())
  name            String
  description     String
  logo            String?
  category        String
  collegeId       String
  verified        Boolean      @default(false)
  rejectionReason String?
  verifiedBy      String?
  verifiedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  college         College      @relation(fields: [collegeId], references: [id])
  members         ClubMember[]
  events          Event[]
  posts           Post[]
  deletedAt       DateTime?

  @@index([collegeId])
  @@index([deletedAt])
}

model ClubMember {
  id       String   @id @default(cuid())
  role     ClubMemberRole
  joinedAt DateTime @default(now())
  userId   String
  clubId   String
  club     Club     @relation(fields: [clubId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, clubId])
  @@index([clubId])  // For getClubMembers()
  @@index([userId])  // For getUserMemberships()
}

model ChatRoom {
  id           String        @id @default(cuid())
  name         String
  type         String
  description  String?
  participants Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  timestamp DateTime @default(now())
  senderId  String
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id])
  sender    User     @relation(fields: [senderId], references: [id])

  @@index([roomId, timestamp])  // For getMessageHistory()
  @@index([senderId])           // For getUserMessages()
}

model Post {
  id        String    @id @default(cuid())
  content   String
  image     String?
  likes     Int       @default(0)
  comments  Int       @default(0)
  timestamp DateTime  @default(now())
  authorId  String
  clubId    String
  replies   Comment[]
  author    User      @relation(fields: [authorId], references: [id])
  club      Club      @relation(fields: [clubId], references: [id])

  @@index([clubId, timestamp])  // For getClubPosts() sorted by date
  @@index([authorId])           // For getUserPosts()
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  timestamp DateTime @default(now())
  authorId  String
  postId    String
  author    User     @relation(fields: [authorId], references: [id])
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])     // For getPostComments()
  @@index([authorId])   // For getUserComments()
}

model Notification {
  id          String   @id @default(cuid())
  message     String
  link        String?
  type        NotificationType
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  recipientId String
  actorId     String?
  actor       User?    @relation("NotificationActor", fields: [actorId], references: [id])
  recipient   User     @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])  // For getUserNotifications() sorted by date
  @@index([recipientId, read])       // For unread notification counts
}

model Conversation {
  id           String                    @id @default(cuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @default(now())
  isGroup      Boolean                   @default(false)
  name         String?
  groupImage   String?
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  userId         String
  conversationId String
  lastReadAt     DateTime     @default(now())
  role           ConversationRole @default(MEMBER)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@unique([userId, conversationId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String       @id @default(cuid())
  content        String
  attachmentUrl  String?
  attachmentType String?
  createdAt      DateTime     @default(now())
  senderId       String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])
  reactions      Reaction[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  messageId String
  userId    String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model TeamRequest {
  id          String          @id @default(cuid())
  eventId     String
  creatorId   String
  creatorName String
  type        TeamRequestType
  skills      String
  description String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  creator     User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  event       Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])    // For event team requests
  @@index([creatorId])  // For user's team requests
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  actorId    String
  details    Json?
  createdAt  DateTime @default(now())
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])

  @@index([createdAt])   // For admin dashboard queries
  @@index([actorId])     // For user audit trail
  @@index([entityType, entityId])  // For entity history
}

model LoginAttempt {
  id        String   @id
  email     String
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

model RefreshToken {
  id        String   @id
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  family    String
  revoked   Boolean  @default(false)
  userAgent String?
  ip        String?
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([family])
  @@index([token])
  @@index([userId])
}
