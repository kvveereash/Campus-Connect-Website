// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  department String?
  year      String?
  avatar    String? // Profile picture URL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastSeenAt DateTime @default(now())
  role      String   @default("USER") // "ADMIN" | "USER" | "COLLEGE_ADMIN"

  // Relationships
  collegeId String?
  college   College? @relation(fields: [collegeId], references: [id])
  
  followedColleges College[] @relation("FollowedColleges")
  registrations    EventRegistration[] // Replace: registeredEvents Event[] @relation("RegisteredEvents")
  createdEvents    Event[]   @relation("CreatedEvents")
  badges           UserBadge[]
  messages         ChatMessage[]

  // Smart Matchmaking
  bio       String?
  skills    Skill[]
  interests Interest[]
  
  // Profile
  resumeUrl String?
  achievements String? // Storing as JSON String for SQLite compatibility
  projects     String?
  portfolioLinks String?
  
  
  clubMemberships ClubMember[]
  posts           Post[]
  comments        Comment[]
  
  notifications          Notification[] @relation("UserNotifications")
  triggeredNotifications Notification[] @relation("NotificationActor")

  conversationParticipations ConversationParticipant[]
  messagesSent               Message[]
  reactions                  Reaction[]
  teamRequests               TeamRequest[]
  auditLogs                  AuditLog[]    @relation("AuditActor")
  passwordResetTokens        PasswordResetToken[]
  eventReviews               EventReview[]

  @@index([email])
  @@index([collegeId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Skill {
  id    String @id @default(cuid())
  name  String @unique
  users User[]
}

model Interest {
  id    String @id @default(cuid())
  name  String @unique
  users User[]
}

model College {
  id          String   @id @default(cuid())
  name        String
  location    String
  logo        String
  description String
  
  // Relationships
  students    User[]
  followers   User[]   @relation("FollowedColleges")
  events      Event[]
  clubs       Club[]
}

model Event {
  id                String   @id @default(cuid())
  title             String
  description       String
  date              DateTime
  venue             String
  category          String
  price             Float    @default(0) // New: Event registration fee
  registrationCount Int      @default(0)
  thumbnail         String?
  
  // Relationships
  registrations EventRegistration[] // Replace: User[] @relation("RegisteredEvents")
  
  hostCollegeId String
  hostCollege   College @relation(fields: [hostCollegeId], references: [id])
  
  creatorId     String?
  creator       User?   @relation("CreatedEvents", fields: [creatorId], references: [id])
  
  clubId        String?
  club          Club?   @relation(fields: [clubId], references: [id])
  verified      Boolean @default(false)
  rejectionReason String?
  verifiedBy    String?
  verifiedAt    DateTime?
  teamRequests  TeamRequest[]
  reviews       EventReview[]

  @@index([hostCollegeId])
  @@index([date])
  @@index([category])
  @@index([creatorId])
}

model EventReview {
  id        String   @id @default(cuid())
  rating    Int      // 1-5 stars
  comment   String?  // Optional review text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, eventId]) // One review per user per event
  @@index([eventId])
  @@index([userId])
}

model EventRegistration {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING") // PENDING, PAID, CANCELLED
  paymentId   String?  // Stripe session ID or transaction ID
  amountPaid  Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  icon        String
  
  // Relationships
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  dateEarned DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model Club {
  id          String   @id @default(cuid())
  name        String
  description String
  logo        String?
  category    String   // e.g., Technical, Cultural, Sports
  
  collegeId   String
  college     College  @relation(fields: [collegeId], references: [id])
  
  members     ClubMember[]
  events      Event[]
  posts       Post[]
  
  verified    Boolean  @default(false)
  rejectionReason String?
  verifiedBy    String?
  verifiedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClubMember {
  id        String   @id @default(cuid())
  role      String   // ADMIN, MEMBER
  joinedAt  DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id])
  
  @@unique([userId, clubId])
}

model ChatRoom {
  id          String   @id @default(cuid())
  name        String
  type        String   // 'topic' or 'college'
  description String?
  participants Int     @default(0) // Determining count usually requires query, but simple counter for now
  
  messages    ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  timestamp DateTime @default(now())
  
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id])
}

model Post {
  id        String   @id @default(cuid())
  content   String
  image     String?
  likes     Int      @default(0)
  comments  Int      @default(0) // Simple counter for now
  timestamp DateTime @default(now())

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  clubId    String
  club      Club     @relation(fields: [clubId], references: [id])
  
  replies   Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  timestamp DateTime @default(now())

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  link      String?
  type      String   // COMMENT, LIKE, SYSTEM, INVITE
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  recipientId String
  recipient   User     @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)

  actorId     String?
  actor       User?    @relation("NotificationActor", fields: [actorId], references: [id])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  participants ConversationParticipant[]
  messages     Message[]

  isGroup      Boolean  @default(false)
  name         String?
  groupImage   String?
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  lastReadAt     DateTime     @default(now())
  role           String       @default("MEMBER") // ADMIN, MEMBER
  
  @@unique([userId, conversationId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String       @id @default(cuid())
  content        String
  attachmentUrl  String?
  attachmentType String?      // 'image', 'video', 'file'
  createdAt      DateTime     @default(now())
  
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  reactions      Reaction[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([messageId, userId, emoji])
}

model TeamRequest {
  id          String   @id @default(cuid())
  
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  creatorName String // Denormalized for simpler display
  type        String // LOOKING_FOR_TEAM | LOOKING_FOR_MEMBER
  skills      String // Stored as JSON string or comma-separated
  description String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // APPROVE, REJECT, DELETE
  entityType String  // CLUB, EVENT, USER
  entityId  String
  actorId   String
  actor     User     @relation("AuditActor", fields: [actorId], references: [id])
  details   String?
  createdAt DateTime @default(now())
}
